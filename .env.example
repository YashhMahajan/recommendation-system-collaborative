# 🎬 Movie Recommendation System - Environment Configuration
# Copy this file to .env and update with your settings

# ===========================================
# 🚀 SERVER SETTINGS
# ===========================================
# Development or Production mode
DEBUG=false

# Server configuration
HOST=0.0.0.0
PORT=8000

# ===========================================
# 📁 DATA & MODEL PATHS
# ===========================================
# Where your trained models live
MODEL_PATH=models

# Where processed data is stored
DATA_PATH=processed_data

# ===========================================
# ⚙️ API SETTINGS
# ===========================================
# Maximum recommendations to return
MAX_RECOMMENDATIONS=50

# Cache time in seconds (5 minutes default)
CACHE_TTL=300

# ===========================================
# 🎭 MOVIE DATA ENRICHMENT (Optional)
# ===========================================
# The Movie Database (TMDB) API for movie posters and details
# Get your free API key from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_URL=https://image.tmdb.org/t/p/w500

# ===========================================
# 📊 LOGGING
# ===========================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file location
LOG_FILE=logs/app.log

# ===========================================
# 🔒 SECURITY
# ===========================================
# Secret key for sessions and security
# Generate a random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# ===========================================
# 🌍 PRODUCTION SETTINGS
# ===========================================
# Uncomment these for production deployment
# DEBUG=false
# HOST=0.0.0.0
# PORT=8000
# LOG_LEVEL=WARNING

# ===========================================
# 🗄️ DATABASE (Future Enhancement)
# ===========================================
# If you want to add database support later
# DATABASE_URL=postgresql://user:password@localhost/movierecs

# ===========================================
# 📈 MONITORING (Optional)
# ===========================================
# For production monitoring
# SENTRY_DSN=your_sentry_dsn_here

# ===========================================
# 🎯 PERFORMANCE TUNING
# ===========================================
# Number of worker processes (for production)
WORKERS=4

# Request timeout in seconds
TIMEOUT=30
